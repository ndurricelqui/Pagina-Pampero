  <!-- ── SCRIPTS ── -->
  <script>
    // Local lightbox
    function openLocalLightbox(src) {
      document.getElementById('localLightboxImg').src = src;
      document.getElementById('localLightbox').classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeLocalLightbox() {
      document.getElementById('localLightbox').classList.remove('open');
      document.body.style.overflow = '';
    }
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLocalLightbox(); });

    // Lazy load galería del local: solo carga la imagen cuando entra en pantalla
    const lazyImgs = document.querySelectorAll('img[data-src]');
    const lazyObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const img = entry.target;
          img.src = img.dataset.src;
          lazyObserver.unobserve(img);
        }
      });
    }, { rootMargin: '200px' });
    lazyImgs.forEach(img => lazyObserver.observe(img));

    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // Hamburger
    const hamburger = document.getElementById('hamburger');
    const navMenu = document.getElementById('navMenu');
    hamburger.addEventListener('click', () => navMenu.classList.toggle('open'));
    navMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => navMenu.classList.remove('open')));

    // Form
    document.getElementById('quoteForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      if (!this.checkValidity()) { this.reportValidity(); return; }

      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> &nbsp;Enviando...';

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
