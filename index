<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pampero Córdoba | Indumentaria Corporativa y de Trabajo</title>
  <meta name="description" content="Pampero Córdoba – Especialistas en indumentaria corporativa y de trabajo para empresas. Uniformes, bordado y pedidos por volumen. Pedí tu presupuesto." />
  <link rel="canonical" href="https://www.pamperocordoba.com" />
  <link rel="icon" type="image/png" href="https://pampero.com.ar/wp-content/uploads/2024/09/FAV_PAMPERO.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Barlow+Condensed:wght@600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <style>
    /* ═══════════════════════════════════════
       RESET & BASE
    ═══════════════════════════════════════ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      font-family: 'Barlow', sans-serif;
      background: #fff;
      color: #111;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    img { display: block; max-width: 100%; }
    a { text-decoration: none; }

    /* ═══════════════════════════════════════
       VARIABLES
    ═══════════════════════════════════════ */
    :root {
      --yellow:  #FFD100;
      --black:   #111111;
      --white:   #FFFFFF;
      --gray-bg: #F4F4F4;
      --gray-mid:#999999;
      --gray-txt:#444444;
      --border:  #E0E0E0;
    }

    /* ═══════════════════════════════════════
       ANNOUNCEMENT BAR
    ═══════════════════════════════════════ */
    .topbar {
      background: var(--yellow);
      color: var(--black);
      text-align: center;
      font-size: .78rem;
      font-weight: 700;
      letter-spacing: .06em;
      text-transform: uppercase;
      padding: .45rem 1rem;
    }

    /* ═══════════════════════════════════════
       NAVBAR
    ═══════════════════════════════════════ */
    .navbar {
      position: sticky; top: 0; z-index: 1000;
      background: var(--black);
      display: flex; align-items: center;
      justify-content: space-between;
      padding: 0 2.5rem;
      height: 70px;
    }
    /* Logo */
    .navbar__logo {
      display: flex; align-items: center; gap: .85rem;
    }
    .navbar__logo img.logo-symbol {
      height: 38px; width: auto;
      filter: brightness(0) invert(1);
    }
    .navbar__logo-sep {
      width: 1px; height: 28px;
      background: #444;
      margin: 0 .5rem;
    }
    .navbar__logo-city {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700; font-size: 1.3rem;
      color: #fff; letter-spacing: .18em;
      text-transform: uppercase;
    }
    /* Nav links */
    .navbar__menu {
      display: flex; align-items: center; gap: 2.5rem; list-style: none;
    }
    .navbar__menu a {
      color: #ccc; font-size: .78rem; font-weight: 600;
      letter-spacing: .1em; text-transform: uppercase;
      transition: color .18s;
    }
    .navbar__menu a:hover { color: var(--yellow); }
    /* CTA */
    .navbar__cta {
      background: var(--yellow); color: var(--black);
      font-size: .75rem; font-weight: 800;
      letter-spacing: .1em; text-transform: uppercase;
      padding: .6rem 1.5rem; border-radius: 2px;
      transition: opacity .18s;
      white-space: nowrap;
    }
    .navbar__cta:hover { opacity: .88; }
    /* Hamburger */
    .hamburger {
      display: none; background: none; border: none; cursor: pointer;
      flex-direction: column; gap: 5px; padding: .25rem;
    }
    .hamburger span {
      display: block; width: 22px; height: 2px; background: #fff; transition: .25s;
    }

    /* ═══════════════════════════════════════
       HERO
    ═══════════════════════════════════════ */
    .hero {
      position: relative; overflow: hidden;
      height: calc(100vh - 70px); min-height: 520px;
    }
    .hero__img {
      width: 100%; height: 100%; object-fit: cover; object-position: center 30%;
    }
    .hero__overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to right, rgba(0,0,0,.72) 0%, rgba(0,0,0,.30) 60%, rgba(0,0,0,.1) 100%);
    }
    .hero__content {
      position: absolute; top: 50%; left: 0;
      transform: translateY(-50%);
      padding: 0 5vw;
      max-width: 680px;
    }
    .hero__eyebrow {
      display: inline-flex; align-items: center; gap: .5rem;
      background: var(--yellow); color: var(--black);
      font-size: .68rem; font-weight: 800;
      letter-spacing: .14em; text-transform: uppercase;
      padding: .3rem .85rem; margin-bottom: 1.25rem;
    }
    .hero__title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900; font-size: clamp(3.2rem, 8vw, 6.5rem);
      color: #fff; line-height: .95; text-transform: uppercase;
      letter-spacing: -.01em; margin-bottom: 1.25rem;
    }
    .hero__title .highlight { color: var(--yellow); }
    .hero__sub {
      font-size: clamp(.95rem, 1.5vw, 1.15rem);
      color: rgba(255,255,255,.82); max-width: 440px;
      margin-bottom: 2.25rem; font-weight: 300;
    }
    .hero__btns { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn {
      display: inline-flex; align-items: center; gap: .5rem;
      font-family: 'Barlow', sans-serif;
      font-size: .8rem; font-weight: 800;
      letter-spacing: .12em; text-transform: uppercase;
      padding: .85rem 2rem; border-radius: 2px;
      transition: all .18s; border: 2px solid transparent;
      cursor: pointer;
    }
    .btn--yellow { background: var(--yellow); color: var(--black); }
    .btn--yellow:hover { background: #e6bc00; }
    .btn--outline-white { background: transparent; color: #fff; border-color: rgba(255,255,255,.55); }
    .btn--outline-white:hover { border-color: #fff; background: rgba(255,255,255,.08); }
    .btn--outline-black { background: transparent; color: var(--black); border-color: var(--black); }
    .btn--outline-black:hover { background: var(--black); color: #fff; }
    .btn--full { width: 100%; justify-content: center; }

    /* ═══════════════════════════════════════
       STRIP / BADGE ROW
    ═══════════════════════════════════════ */
    .strip {
      background: var(--black);
      display: flex; justify-content: center; align-items: center;
      flex-wrap: wrap; gap: 0;
      border-bottom: 1px solid #222;
    }
    .strip__item {
      display: flex; align-items: center; gap: .65rem;
      padding: 1.1rem 2.5rem;
      color: #bbb; font-size: .75rem; font-weight: 600;
      letter-spacing: .08em; text-transform: uppercase;
      border-right: 1px solid #2a2a2a;
    }
    .strip__item:last-child { border-right: none; }
    .strip__item i { color: var(--yellow); font-size: 1rem; }

    /* ═══════════════════════════════════════
       SECTIONS BASE
    ═══════════════════════════════════════ */
    .section { padding: 90px 2.5rem; }
    .section--gray { background: var(--gray-bg); }
    .section--black { background: var(--black); }
    .container { max-width: 1200px; margin: 0 auto; }

    .section-label {
      display: inline-block;
      font-size: .68rem; font-weight: 800;
      letter-spacing: .18em; text-transform: uppercase;
      color: var(--gray-mid); margin-bottom: .65rem;
    }
    .section-label--yellow { color: var(--yellow); }
    .section-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900; font-size: clamp(2.2rem, 4vw, 3.4rem);
      text-transform: uppercase; line-height: 1;
      letter-spacing: -.01em; color: var(--black);
      margin-bottom: 1rem;
    }
    .section-title--white { color: #fff; }
    .section-desc { color: var(--gray-txt); font-size: 1rem; max-width: 520px; }
    .section-desc--light { color: #999; }

    /* ═══════════════════════════════════════
       LINES / CATEGORIES
    ═══════════════════════════════════════ */
    .lines__header {
      display: flex; justify-content: space-between; align-items: flex-end;
      margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem;
    }
    .lines__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px; background: var(--border);
    }
    .instagram-banner {
      margin-top: 2.5rem;
      background: linear-gradient(135deg, #833ab4 0%, #fd1d1d 50%, #fcb045 100%);
      padding: 2.5rem 2rem;
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 1.5rem;
      border-radius: 2px;
    }
    .instagram-banner__text { color: #fff; }
    .instagram-banner__text p {
      font-size: .8rem; font-weight: 700; letter-spacing: .12em;
      text-transform: uppercase; opacity: .85; margin-bottom: .4rem;
    }
    .instagram-banner__text h3 {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900; font-size: 1.75rem;
      text-transform: uppercase; line-height: 1;
    }
    .instagram-banner__text span {
      font-size: .9rem; opacity: .9; font-weight: 300; display: block; margin-top: .4rem;
    }
    .instagram-banner__cta {
      display: inline-flex; align-items: center; gap: .6rem;
      background: #fff; color: #833ab4;
      font-size: .8rem; font-weight: 800; letter-spacing: .1em;
      text-transform: uppercase; padding: .85rem 1.75rem;
      border-radius: 2px; transition: opacity .18s; white-space: nowrap;
    }
    .instagram-banner__cta:hover { opacity: .88; }
    .line-card {
      position: relative; overflow: hidden;
      background: var(--gray-bg);
      aspect-ratio: 3/4;
      cursor: pointer;
    }
    .line-card img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform .5s ease;
    }
    .line-card:hover img { transform: scale(1.04); }
    .line-card__overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,.8) 0%, rgba(0,0,0,0) 55%);
    }
    .line-card:hover .line-card__overlay {
      background: linear-gradient(to top, rgba(0,0,0,.9) 0%, rgba(0,0,0,.1) 55%);
    }
    .line-card__body {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 1.5rem;
    }
    .line-card__tag {
      display: inline-block;
      background: var(--yellow); color: var(--black);
      font-size: .6rem; font-weight: 800;
      letter-spacing: .14em; text-transform: uppercase;
      padding: .18rem .6rem; margin-bottom: .5rem;
    }
    .line-card__title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900; font-size: 1.8rem;
      color: #fff; text-transform: uppercase;
      line-height: 1; margin-bottom: .35rem;
    }
    .line-card__desc {
      font-size: .78rem; color: rgba(255,255,255,.7);
      line-height: 1.5;
    }
    .line-card__arrow {
      display: inline-flex; align-items: center; gap: .4rem;
      font-size: .7rem; font-weight: 700; color: var(--yellow);
      letter-spacing: .1em; text-transform: uppercase;
      margin-top: .75rem; opacity: 0; transform: translateY(4px);
      transition: opacity .25s, transform .25s;
    }
    .line-card:hover .line-card__arrow { opacity: 1; transform: none; }

    /* ═══════════════════════════════════════
       PRODUCT HIGHLIGHTS
    ═══════════════════════════════════════ */
    .products__header {
      display: flex; justify-content: space-between; align-items: flex-end;
      margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem;
    }

    /* Chosen categories grid */
    .chosen__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    .chosen-cat {
      position: relative; overflow: hidden;
      background: var(--gray-bg);
      cursor: pointer;
    }
    .chosen-cat__img-wrap {
      position: relative;
      aspect-ratio: 3/4;
      overflow: hidden;
    }
    .chosen-cat__img-wrap img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center top;
      transition: transform .5s ease;
    }
    .chosen-cat:hover .chosen-cat__img-wrap img { transform: scale(1.04); }
    .chosen-cat__overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,.82) 0%, rgba(0,0,0,.1) 55%);
    }
    .chosen-cat:hover .chosen-cat__overlay {
      background: linear-gradient(to top, rgba(0,0,0,.9) 0%, rgba(0,0,0,.18) 55%);
    }
    .chosen-cat__body {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 1.5rem;
    }
    .chosen-cat__tag {
      display: inline-block;
      background: var(--yellow); color: var(--black);
      font-size: .6rem; font-weight: 800;
      letter-spacing: .14em; text-transform: uppercase;
      padding: .18rem .6rem; margin-bottom: .5rem;
    }
    .chosen-cat__title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900; font-size: 1.9rem;
      color: #fff; text-transform: uppercase;
      line-height: 1; margin-bottom: .35rem;
    }
    .chosen-cat__desc {
      font-size: .78rem; color: rgba(255,255,255,.72);
      line-height: 1.55;
    }
    .chosen-cat__arrow {
      display: inline-flex; align-items: center; gap: .4rem;
      font-size: .7rem; font-weight: 700; color: var(--yellow);
      letter-spacing: .1em; text-transform: uppercase;
      margin-top: .75rem; opacity: 0; transform: translateY(4px);
      transition: opacity .25s, transform .25s;
    }
    .chosen-cat:hover .chosen-cat__arrow { opacity: 1; transform: none; }
    a.chosen-cat { display: block; color: inherit; }

    /* 4-column chosen grid */
    .chosen__grid--4 { grid-template-columns: repeat(4, 1fr); }
    /* 5-column chosen grid */
    .chosen__grid--5 { grid-template-columns: repeat(5, 1fr); gap: 1rem; }
    .chosen__grid--5 .chosen-cat__img-wrap { aspect-ratio: 2/3; }
    .chosen__grid--5 .chosen-cat__title { font-size: 1.5rem; }
    .chosen__grid--5 .chosen-cat__body { padding: 1rem; }

    /* Categorías intro text */
    .cats-intro { margin-bottom: 2.5rem; max-width: 760px; }
    .cats-intro p { font-size: .97rem; color: var(--gray-txt); line-height: 1.8; margin-bottom: .85rem; }
    .cats-intro p:last-child { margin-bottom: 0; }
    .cats-intro strong { color: var(--black); }

    /* ═══════════════════════════════════════
       ABOUT / NOSOTROS
    ═══════════════════════════════════════ */
    .about__grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 5rem; align-items: center;
    }
    .about__img-wrap { position: relative; }
    .about__img {
      width: 100%; aspect-ratio: 4/5; object-fit: cover;
      object-position: center top;
    }
    .about__img-stamp {
      position: absolute; bottom: -1.5rem; right: -1.5rem;
      width: 140px; height: 140px;
      background: var(--yellow);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
    }
    .about__img-stamp strong {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900; font-size: 2.8rem;
      color: var(--black); line-height: 1;
    }
    .about__img-stamp span {
      font-size: .62rem; font-weight: 800;
      color: var(--black); letter-spacing: .1em;
      text-transform: uppercase; text-align: center;
      line-height: 1.3;
    }
    .about__list { margin-top: 2rem; display: flex; flex-direction: column; gap: 1.5rem; }
    .about__item { display: flex; gap: 1.1rem; align-items: flex-start; }
    .about__item-num {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900; font-size: 2rem; color: var(--yellow);
      line-height: 1; min-width: 2rem; text-align: right;
    }
    .about__item-text h4 {
      font-weight: 700; font-size: .9rem;
      text-transform: uppercase; letter-spacing: .05em;
      margin-bottom: .2rem;
    }
    .about__item-text p { font-size: .88rem; color: var(--gray-txt); }

    /* ═══════════════════════════════════════
       WHY US
    ═══════════════════════════════════════ */
    .why__header { margin-bottom: 3rem; }
    .why__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px; background: #222;
    }
    .why-card {
      background: var(--black); padding: 2.5rem 2rem;
      transition: background .2s;
    }
    .why-card:hover { background: #1a1a1a; }
    .why-card__icon {
      font-size: 1.6rem; color: var(--yellow);
      margin-bottom: 1.25rem;
    }
    .why-card h3 {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900; font-size: 1.25rem;
      text-transform: uppercase; color: #fff;
      letter-spacing: .04em; margin-bottom: .6rem;
    }
    .why-card p { font-size: .85rem; color: #777; line-height: 1.65; }

    /* ═══════════════════════════════════════
       QUOTE / FORM
    ═══════════════════════════════════════ */
    .quote__grid {
      display: grid; grid-template-columns: 1fr 1.5fr;
      gap: 5rem; align-items: start;
    }
    .quote__info { position: sticky; top: 90px; }
    .quote__contact { margin-top: 2rem; display: flex; flex-direction: column; gap: 1.25rem; }
    .quote__citem {
      display: flex; gap: .9rem; align-items: center;
      padding-bottom: 1.25rem; border-bottom: 1px solid var(--border);
    }
    .quote__citem:last-child { border-bottom: none; }
    .quote__citem-icon {
      width: 40px; height: 40px; flex-shrink: 0;
      background: var(--yellow);
      display: flex; align-items: center; justify-content: center;
      color: var(--black); font-size: .95rem;
    }
    .quote__citem span { font-size: .75rem; color: var(--gray-mid); text-transform: uppercase; letter-spacing: .06em; display: block; }
    .quote__citem strong { font-size: .92rem; color: var(--black); }

    /* Form */
    .form {
      background: var(--gray-bg);
      padding: 2.5rem;
    }
    .form__title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900; font-size: 1.5rem;
      text-transform: uppercase; margin-bottom: 1.75rem;
      padding-bottom: 1.25rem; border-bottom: 2px solid var(--yellow);
    }
    .form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form__group { margin-bottom: 1.1rem; }
    .form__group label {
      display: block; font-size: .72rem; font-weight: 800;
      text-transform: uppercase; letter-spacing: .1em;
      color: var(--black); margin-bottom: .4rem;
    }
    .form__group input,
    .form__group select,
    .form__group textarea {
      width: 100%; padding: .75rem 1rem;
      border: 1.5px solid var(--border);
      background: #fff; font-family: 'Barlow', sans-serif;
      font-size: .92rem; color: var(--black);
      border-radius: 0; outline: none;
      transition: border-color .18s;
      -webkit-appearance: none;
    }
    .form__group input:focus,
    .form__group select:focus,
    .form__group textarea:focus { border-color: var(--yellow); }
    .form__group textarea { resize: vertical; min-height: 100px; }
    .form__check {
      display: flex; gap: .65rem; align-items: flex-start;
      margin-bottom: 1.5rem;
    }
    .form__check input { width: auto; margin-top: .2rem; accent-color: var(--yellow); }
    .form__check label {
      font-size: .8rem; color: var(--gray-txt);
      font-weight: 400; text-transform: none; letter-spacing: 0;
    }
    .btn--submit {
      background: var(--black); color: #fff;
      width: 100%; justify-content: center;
      font-size: .82rem; padding: 1.1rem;
      border: 2px solid var(--black);
      transition: background .18s, color .18s;
    }
    .btn--submit:hover { background: #fff; color: var(--black); }
    #formSuccess {
      display: none; text-align: center; padding: 3rem 2rem;
    }
    #formSuccess i { font-size: 3rem; color: var(--yellow); display: block; margin-bottom: 1rem; }
    #formSuccess h3 { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 1.75rem; text-transform: uppercase; margin-bottom: .5rem; }
    #formSuccess p { color: var(--gray-txt); font-size: .9rem; }

    /* ═══════════════════════════════════════
       WHATSAPP FLOAT
    ═══════════════════════════════════════ */
    .wa {
      position: fixed; bottom: 1.75rem; right: 1.75rem; z-index: 900;
      background: #25D366; color: #fff;
      width: 56px; height: 56px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.55rem;
      box-shadow: 0 4px 18px rgba(37,211,102,.55);
      transition: transform .2s;
    }
    .wa:hover { transform: scale(1.1); color: #fff; }
    .wa__label {
      position: absolute; right: 66px;
      background: #25D366; color: #fff;
      font-size: .82rem; font-weight: 600;
      white-space: nowrap; padding: .35rem .75rem;
      border-radius: 2rem;
      box-shadow: 0 3px 12px rgba(37,211,102,.4);
      opacity: 0; transform: translateX(8px);
      transition: opacity .25s, transform .25s;
      pointer-events: none;
    }
    .wa:hover .wa__label { opacity: 1; transform: translateX(0); }
    .wa__pulse {
      position: absolute; inset: -5px;
      border-radius: 50%; border: 2px solid rgba(37,211,102,.4);
      animation: wapulse 2.2s infinite;
    }
    @keyframes wapulse { 0%,100%{transform:scale(1);opacity:.8} 50%{transform:scale(1.18);opacity:.3} }

    /* ═══════════════════════════════════════
       FOOTER
    ═══════════════════════════════════════ */
    footer {
      background: #0a0a0a; color: #666;
      padding: 4rem 2.5rem 2rem;
    }
    .footer__grid {
      max-width: 1200px; margin: 0 auto;
      display: grid; grid-template-columns: 2.5fr 1fr 1fr 1fr;
      gap: 3rem; padding-bottom: 3rem;
      border-bottom: 1px solid #1e1e1e;
    }
