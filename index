                  'https://pampero.com.ar/wp-content/uploads/2025/10/PAMPERO-PRODUCTO-DIA-31898-1.jpg',
                ]
              },
            ]
          },
          {
            name: 'Protector Auditivo Alerces',
            desc: 'Protector auditivo tipo copa Pampero. Diseño ergonómico para uso prolongado en entornos industriales.',
            sizes: 'TU',
            img: 'https://d1cwu3ie96gcvw.cloudfront.net/articulo_imagen/104/_ILM0829-Editar_1761057574.jpg',
            imgContain: true,
            colors: [
              {
                label: 'Amarillo', hex: '#FFD100',
                img: 'https://d1cwu3ie96gcvw.cloudfront.net/articulo_imagen/104/_ILM0829-Editar_1761057574.jpg',
                imgs: [
                  'https://d1cwu3ie96gcvw.cloudfront.net/articulo_imagen/104/_ILM0829-Editar_1761057574.jpg',
                ]
              },
            ]
          },
          {
            name: 'Protector Auditivo Pacífico',
            desc: 'Protector auditivo tipo copa Pampero. Diseño ergonómico para uso prolongado en entornos industriales.',
            sizes: 'TU',
            img: 'https://d1cwu3ie96gcvw.cloudfront.net/articulo_imagen/104/_ILM0825-Editar_1761057609.jpg',
            imgContain: true,
            colors: [
              {
                label: 'Amarillo', hex: '#FFD100',
                img: 'https://d1cwu3ie96gcvw.cloudfront.net/articulo_imagen/104/_ILM0825-Editar_1761057609.jpg',
                imgs: [
                  'https://d1cwu3ie96gcvw.cloudfront.net/articulo_imagen/104/_ILM0825-Editar_1761057609.jpg',
                ]
              },
            ]
          },
        ]
      }
    };

    var catView = document.getElementById('catView');
    var prodView = document.getElementById('prodView');
    var prodPageTitle = document.getElementById('prodPageTitle');
    var prodPageGrid = document.getElementById('prodPageGrid');
    var backBtn = document.getElementById('backBtn');

    function switchProductColor(btn, colorLabel, colorImg, defaultImg, productName) {
      var card = btn.closest('.prod-card');
      var img = card.querySelector('.prod-card__img img');
      var lbl = card.querySelector('.prod-card__color-label');
      var waBtn = card.querySelector('.prod-card__btn');
      img.src = colorImg || defaultImg;
      if (lbl) lbl.textContent = colorLabel;
      card.querySelectorAll('.color-swatch').forEach(function(s) { s.classList.remove('active'); });
      btn.classList.add('active');
      var msg = encodeURIComponent('Hola Pampero Córdoba! Quiero consultar sobre ' + productName + ' — ' + colorLabel);
      waBtn.href = 'https://wa.me/5493513104836?text=' + msg;
    }

    function imgStyle(p) {
      return p.imgContain ? ' style="object-fit:contain;object-position:center center;background:#fff"' : '';
    }

    function renderCard(p) {
      var extraMeta = '';
      if (p.desc) extraMeta += '<p class="prod-card__desc">' + p.desc + '</p>';
      if (p.sizes) extraMeta += '<span class="prod-card__sizes"><i class="fas fa-ruler-horizontal" style="margin-right:.3rem"></i>Talles: ' + p.sizes + '</span>';

      if (p.colors && p.colors.length) {
        var first = p.colors[0];
        var firstImg = first.img || p.img;
        var swatches = p.colors.map(function(c, i) {
          var activeClass = i === 0 ? ' active' : '';
          var whiteClass = c.white ? ' color-swatch--white' : '';
          var cImg = c.img ? "'" + c.img + "'" : 'null';
          var safeLabel = c.label.replace(/'/g, "\\'");
          var safeName = p.name.replace(/'/g, "\\'");
          return '<button class="color-swatch' + activeClass + whiteClass + '"' +
            ' style="background:' + c.hex + '"' +
            ' title="' + c.label + '"' +
            ' onclick="switchProductColor(this,\'' + safeLabel + '\',' + cImg + ',\'' + p.img + '\',\'' + safeName + '\')"></button>';
        }).join('');
        var firstMsg = encodeURIComponent('Hola Pampero Córdoba! Quiero consultar sobre ' + p.name + ' — ' + first.label);
        return '<div class="prod-card">' +
          '<div class="prod-card__img"><img src="' + firstImg + '" alt="' + p.name + '" loading="lazy"' + imgStyle(p) + ' /></div>' +
          '<div class="prod-card__body">' +
          '<p class="prod-card__name">' + p.name + '</p>' +
          extraMeta +
          '<div class="prod-card__color-label">' + first.label + '</div>' +
          '<div class="prod-card__colors">' + swatches + '</div>' +
          '<a class="prod-card__btn" href="https://wa.me/5493513104836?text=' + firstMsg + '" target="_blank" rel="noopener">' +
          '<i class="fab fa-whatsapp"></i> Consultar</a>' +
          '</div></div>';
      } else {
        var msg = encodeURIComponent('Hola Pampero Córdoba! Quiero consultar sobre ' + p.name);
        return '<div class="prod-card">' +
          '<div class="prod-card__img"><img src="' + p.img + '" alt="' + p.name + '" loading="lazy"' + imgStyle(p) + ' /></div>' +
          '<div class="prod-card__body">' +
          '<p class="prod-card__name">' + p.name + '</p>' +
          extraMeta +
          '<a class="prod-card__btn" href="https://wa.me/5493513104836?text=' + msg + '" target="_blank" rel="noopener">' +
          '<i class="fab fa-whatsapp"></i> Consultar</a>' +
          '</div></div>';
      }
    }

    function goToCategory(cat) {
      var data = PRODUCTS[cat];
      if (!data) return;
      prodPageTitle.textContent = data.label;
      prodPageGrid.innerHTML = data.items.map(renderCard).join('');
      catView.style.opacity = '0';
      setTimeout(function() {
        catView.style.display = 'none';
        prodView.style.display = 'block';
        setTimeout(function() { prodView.style.opacity = '1'; }, 10);
        document.getElementById('lineas').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 200);
    }

    function backToCategories() {
      prodView.style.opacity = '0';
      setTimeout(function() {
        prodView.style.display = 'none';
        catView.style.display = 'block';
        setTimeout(function() { catView.style.opacity = '1'; }, 10);
        document.getElementById('lineas').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 200);
    }

    document.querySelectorAll('.line-card[data-cat]').forEach(function(card) {
      card.addEventListener('click', function() {
        goToCategory(this.dataset.cat);
      });
    });

    backBtn.addEventListener('click', backToCategories);

    // ── PRODUCT MODAL ──────────────────────────────────────────
    var modalOverlay  = document.getElementById('modalOverlay');
    var modalMainImg  = document.getElementById('modalMainImg');
    var modalThumbs   = document.getElementById('modalThumbs');
    var modalCat      = document.getElementById('modalCat');
    var modalName     = document.getElementById('modalName');
    var modalDesc     = document.getElementById('modalDesc');
    var modalSizesWrap= document.getElementById('modalSizesWrap');
    var modalSizes    = document.getElementById('modalSizes');
    var modalColorsSection = document.getElementById('modalColorsSection');
    var modalColorName= document.getElementById('modalColorName');
    var modalSwatches = document.getElementById('modalSwatches');
    var modalWa       = document.getElementById('modalWa');
    var modalClose    = document.getElementById('modalClose');

    var _modalProduct = null;
    var _modalColorIdx = 0;

    function modalSetMainImage(src) {
      modalMainImg.style.opacity = '0';
      setTimeout(function() {
        modalMainImg.src = src;
        modalMainImg.style.opacity = '1';
      }, 150);
    }

    function modalRenderGallery(imgs, activeIdx) {
      activeIdx = activeIdx || 0;
      modalMainImg.src = imgs[0];
      modalMainImg.style.opacity = '1';
      modalThumbs.innerHTML = imgs.map(function(url, i) {
        return '<div class="modal__thumb' + (i === activeIdx ? ' active' : '') + '" data-idx="' + i + '">' +
          '<img src="' + url + '" loading="lazy" /></div>';
      }).join('');
      modalThumbs.querySelectorAll('.modal__thumb').forEach(function(t) {
        t.addEventListener('click', function() {
          var idx = parseInt(this.dataset.idx);
          modalSetMainImage(imgs[idx]);
          modalThumbs.querySelectorAll('.modal__thumb').forEach(function(x) { x.classList.remove('active'); });
          this.classList.add('active');
        });
      });
    }

    function modalSelectColor(colorIdx) {
      _modalColorIdx = colorIdx;
      var p = _modalProduct;
      var c = p.colors[colorIdx];
      modalColorName.textContent = c.label;
      var imgs = c.imgs && c.imgs.length ? c.imgs : (c.img ? [c.img] : [p.img]);
      modalRenderGallery(imgs, 0);
      modalSwatches.querySelectorAll('.modal__swatch').forEach(function(s, i) {
        s.classList.toggle('active', i === colorIdx);
      });
      var msg = encodeURIComponent('Hola Pampero Córdoba! Quiero consultar sobre ' + p.name + ' — ' + c.label);
      modalWa.href = 'https://wa.me/5493513104836?text=' + msg;
    }

    function openModal(product, catLabel, initColorIdx) {
      _modalProduct = product;
      _modalColorIdx = initColorIdx || 0;

      modalCat.textContent = catLabel || 'Venta Corporativa';
      modalName.textContent = product.name;
      modalDesc.innerHTML = product.desc || '';
      modalDesc.style.display = product.desc ? 'block' : 'none';

      if (product.sizes) {
        modalSizes.textContent = product.sizes;
        modalSizesWrap.style.display = 'flex';
      } else {
        modalSizesWrap.style.display = 'none';
      }

      var containStyle = product.imgContain ? 'object-fit:contain;object-position:center center;background:#fff' : '';
      modalMainImg.style.cssText = containStyle;

      if (product.colors && product.colors.length) {
        modalColorsSection.style.display = 'block';
        modalSwatches.innerHTML = product.colors.map(function(c, i) {
          var whiteClass = c.white ? ' modal__swatch--white' : '';
          return '<button class="modal__swatch' + whiteClass + '" style="background:' + c.hex + '" title="' + c.label + '"></button>';
        }).join('');
        modalSwatches.querySelectorAll('.modal__swatch').forEach(function(btn, i) {
          btn.addEventListener('click', function() { modalSelectColor(i); });
        });
        modalSelectColor(_modalColorIdx);
      } else {
        modalColorsSection.style.display = 'none';
        var imgs = product.imgs ? product.imgs : [product.img];
        modalRenderGallery(imgs, 0);
        var msg = encodeURIComponent('Hola Pampero Córdoba! Quiero consultar sobre ' + product.name);
        modalWa.href = 'https://wa.me/5493513104836?text=' + msg;
      }

      document.body.style.overflow = 'hidden';
      modalOverlay.classList.add('open');
    }

    function closeModal() {
      modalOverlay.classList.remove('open');
      document.body.style.overflow = '';
    }

    modalClose.addEventListener('click', closeModal);
    modalOverlay.addEventListener('click', function(e) {
      if (e.target === modalOverlay) closeModal();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeModal();
    });

    // Delegate click on prod-card images and names to open modal
    document.addEventListener('click', function(e) {
      var imgWrap = e.target.closest('.prod-card__img');
      var nameEl  = e.target.closest('.prod-card__name');
      if (!imgWrap && !nameEl) return;
      var card = (imgWrap || nameEl).closest('.prod-card');
      if (!card) return;
      var grid = card.closest('.prod-page__grid');
      if (!grid) return;
      var catKey = document.getElementById('prodPageTitle').textContent.toLowerCase();
      var catData = null;
      Object.keys(PRODUCTS).forEach(function(k) {
        if (PRODUCTS[k].label.toLowerCase() === catKey) catData = PRODUCTS[k];
      });
      if (!catData) return;
      var cards = Array.from(grid.querySelectorAll('.prod-card'));
      var cardIdx = cards.indexOf(card);
      if (cardIdx < 0 || !catData.items[cardIdx]) return;
      // detect currently active color swatch index
      var activeSwatchIdx = 0;
      var swatches = card.querySelectorAll('.color-swatch');
      swatches.forEach(function(s, i) { if (s.classList.contains('active')) activeSwatchIdx = i; });
      openModal(catData.items[cardIdx], catData.label, activeSwatchIdx);
    });
  </script>
</body>
